# Configuration de sécurité pour GitHub Pages
# Ces en-têtes de sécurité sont appliqués pour renforcer la protection des paiements

# Redirect Stripe Payment Links avec les bons headers
/payment/* https://buy.stripe.com/:splat 301

# Interdire l'accès aux fichiers sensibles
/.*\.env HTTP/1.1 403
/.git/* HTTP/1.1 403
/node_modules/* HTTP/1.1 403
/.htaccess HTTP/1.1 403

# Forcer HTTPS
/* https://:splat 301

# Headers de sécurité par défaut pour Netlify (si migration)
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Content-Security-Policy: default-src 'self' https:; script-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://buy.stripe.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: https:; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://buy.stripe.com; frame-src https://buy.stripe.com
  Permissions-Policy: geolocation=(), microphone=(), camera=()
